{
  "name": "FTR10-Hermes-VSCode",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.5.6",
  "publisher": "FTR10",
  "icon": "media/icon.png",
  "license": "MIT",
  "author": "acester822",
  "contributors": [
    {
      "name": "acester822",
      "email": "acester822@gmail.com"
    }
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Chat",
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "walkthroughs": [
      {
        "id": "hermes.setup",
        "title": "Get Started with Hermes",
        "description": "Configure your agent in 3 easy steps.",
        "steps": [
          {
            "id": "setApiKey",
            "title": "1. Secure your API Key",
            "description": "Store your key securely in VS Code.",
            "media": {
              "markdown": "media/setup-key.md"
            },
            "completionEvents": [
              "onCommand:hermes.setApiKey"
            ]
          },
          {
            "id": "configureAgent",
            "title": "2. Open the Control Center",
            "description": "Customize your agent's persona and tool permissions.",
            "media": {
              "markdown": "media/setup-ui.md"
            },
            "completionEvents": [
              "onCommand:hermes.openControlCenter"
            ]
          },
          {
            "id": "startChat",
            "title": "3. Start a Conversation",
            "description": "Ask Hermes a question about your code.",
            "media": {
              "markdown": "media/setup-chat.md"
            },
            "completionEvents": [
              "onCommand:hermes.newChat"
            ]
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hermes-sidebar",
          "title": "%viewsContainers.activitybar.title%",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "hermes-sidebar": [
        {
          "type": "webview",
          "id": "hermesChat",
          "name": "%views.hermesChat.name%",
          "icon": "media/icon.svg",
          "dropMimeTypes": ["text/uri-list", "application/vnd.code.tree.hermesChat", "files"]
        }
      ]
    },
    "commands": [
      {
        "command": "hermes.askAboutFile",
        "title": "Ask Hermes about this file"
      },
      {
        "command": "hermes.explainFunction",
        "title": "Explain this function"
      },
      {
        "command": "hermes.showDiff",
        "title": "Show Diff"
      },
      {
        "command": "hermes.previewDiff",
        "title": "Preview Hermes Changes"
      },
      {
        "command": "hermes.applyDiff",
        "title": "Apply Hermes Changes"
      },
      {
        "command": "hermes.setApiKey",
        "title": "%commands.hermes.setApiKey.title%"
      },
      {
        "command": "hermes.newChat",
        "title": "%commands.hermes.newChat.title%",
        "icon": "$(add)"
      },
      {
        "command": "hermes.openChat",
        "title": "%commands.hermes.openChat.title%"
      },
      {
        "command": "hermes.sendSelection",
        "title": "%commands.hermes.sendSelection.title%"
      },
      {
        "command": "hermes.reloadExtension",
        "title": "%commands.hermes.reloadExtension.title%",
        "icon": "$(debug-restart)"
      },
      {
        "command": "hermes.reloadSession",
        "title": "%commands.hermes.reloadSession.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "hermes.reloadConfig",
        "title": "%commands.hermes.reloadConfig.title%",
        "icon": "$(sync)"
      },
      {
        "command": "hermes.openSettings",
        "title": "%commands.hermes.openSettings.title%",
        "icon": "$(gear)"
      },
      {
        "command": "hermes.checkUpdate",
        "title": "%commands.hermes.checkUpdate.title%",
        "icon": "$(cloud-download)"
      },
      {
        "command": "hermes.openAbout",
        "title": "%commands.hermes.openAbout.title%",
        "icon": "$(info)"
      },
      {
        "command": "hermes.openHelp",
        "title": "%commands.hermes.openHelp.title%",
        "icon": "$(question)"
      },
      {
        "command": "hermes.openFaq",
        "title": "%commands.hermes.openFaq.title%",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "hermes.openLogs",
        "title": "%commands.hermes.openLogs.title%",
        "icon": "$(output)"
      },
      {
        "command": "hermes.configureEnvironment",
        "title": "%commands.hermes.configureEnvironment.title%",
        "icon": "$(settings-gear)"
      },
      {
        "command": "hermes.openControlCenter",
        "title": "Open Control Center",
        "icon": "$(dashboard)"
      },
      {
        "command": "hermes.openSessionMenu",
        "title": "Open Session Menu",
        "icon": "$(history)"
      }
    ],
    "submenus": [
      {
        "id": "hermes.quickActions",
        "label": "%submenus.hermes.quickActions.label%",
        "icon": "$(ellipsis)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "hermes.newChat",
          "when": "view == hermesChat",
          "group": "navigation@0"
        },
        {
          "command": "hermes.openControlCenter",
          "when": "view == hermesChat",
          "group": "navigation@1"
        },
        {
          "command": "hermes.openSessionMenu",
          "when": "view == hermesChat",
          "group": "navigation@1.5"
        },
        {
          "command": "hermes.openSettings",
          "when": "view == hermesChat",
          "group": "navigation@2"
        },
        {
          "command": "hermes.reloadConfig",
          "when": "view == hermesChat",
          "group": "navigation@3"
        },
        {
          "command": "hermes.reloadExtension",
          "when": "view == hermesChat",
          "group": "navigation@4"
        },
        {
          "submenu": "hermes.quickActions",
          "when": "view == hermesChat",
          "group": "navigation@9"
        }
      ],
      "hermes.quickActions": [
        {
          "command": "hermes.reloadExtension",
          "group": "1@1"
        },
        {
          "command": "hermes.reloadConfig",
          "group": "1@2"
        },
        {
          "command": "hermes.openLogs",
          "group": "2@1"
        },
        {
          "command": "hermes.openSettings",
          "group": "2@2"
        },
        {
          "command": "hermes.checkUpdate",
          "group": "3@1"
        },
        {
          "command": "hermes.configureEnvironment",
          "when": "!hermesDetectInProgress",
          "group": "3@2"
        },
        {
          "command": "hermes.openAbout",
          "group": "4@1"
        },
        {
          "command": "hermes.openHelp",
          "group": "4@2"
        },
        {
          "command": "hermes.openFaq",
          "group": "4@3"
        }
      ],
      "editor/context": [
        {
          "command": "hermes.sendSelection",
          "group": "1_modification"
        }
      ]
    },
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "hermes.path": {
          "type": "string",
          "default": "",
          "description": "%configuration.hermes.path.description%"
        },
        "hermes.cwd": {
          "type": "string",
          "default": "",
          "description": "%configuration.hermes.cwd.description%"
        },
        "hermes.profile": {
          "type": "string",
          "default": "",
          "description": "%configuration.hermes.profile.description%"
        },
        "hermes.showThoughts": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.hermes.showThoughts.description%"
        },
        "hermes.showToolCalls": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.hermes.showToolCalls.description%"
        },
        "hermes.permissionMode": {
          "type": "string",
          "default": "manual",
          "enum": [
            "manual",
            "autoApprove",
            "yolo",
            "denyAll"
          ],
          "enumDescriptions": [
            "%configuration.hermes.permissionMode.manual.description%",
            "%configuration.hermes.permissionMode.autoApprove.description%",
            "%configuration.hermes.permissionMode.yolo.description%",
            "%configuration.hermes.permissionMode.denyAll.description%"
          ],
          "description": "%configuration.hermes.permissionMode.description%"
        },
        "hermes.reasoningEffort": {
          "type": "string",
          "default": "medium",
          "enum": [
            "none",
            "minimal",
            "low",
            "medium",
            "high",
            "xhigh"
          ],
          "enumDescriptions": [
            "%configuration.hermes.reasoningEffort.none.description%",
            "%configuration.hermes.reasoningEffort.minimal.description%",
            "%configuration.hermes.reasoningEffort.low.description%",
            "%configuration.hermes.reasoningEffort.medium.description%",
            "%configuration.hermes.reasoningEffort.high.description%",
            "%configuration.hermes.reasoningEffort.xhigh.description%"
          ],
          "description": "%configuration.hermes.reasoningEffort.description%"
        },
        "hermes.contextAttachVisibility": {
          "type": "string",
          "default": "onNewSession",
          "enum": [
            "onNewSession",
            "always",
            "never"
          ],
          "enumDescriptions": [
            "%configuration.hermes.contextAttachVisibility.onNewSession.description%",
            "%configuration.hermes.contextAttachVisibility.always.description%",
            "%configuration.hermes.contextAttachVisibility.never.description%"
          ],
          "description": "%configuration.hermes.contextAttachVisibility.description%"
        },
        "hermes.models": {
          "type": "array",
          "default": [],
          "description": "%configuration.hermes.models.description%",
          "markdownDescription": "%configuration.hermes.models.markdownDescription%",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "name"
            ]
          }
        },
        "hermes.defaultModel": {
          "type": "string",
          "default": "",
          "description": "%configuration.hermes.defaultModel.description%"
        },
        "hermes.agents": {
          "type": "array",
          "default": [],
          "description": "%configuration.hermes.agents.description%",
          "markdownDescription": "%configuration.hermes.agents.markdownDescription%",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "profile": {
                "type": "string"
              },
              "cwd": {
                "type": "string"
              }
            },
            "required": [
              "name"
            ]
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "test": "xvfb-run -a node ./out/tests/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^3.0.0",
    "mocha": "^11.7.6",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.28.0",
    "ws": "^8.21.0",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/acester822/FTR10-Hermes-VSCode"
  }
}
