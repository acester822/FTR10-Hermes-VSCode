{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Extension",
            "type": "extensionHost",
            "request": "launch",
            "program": "${workspaceFolder}",
            "args": [
                "--extensionDevelopmentPath=/home/ftr/Apps/FTR10-Hermes-VSCode",
                "--disable-extensions",
                "--no-cache"
            ],
            "cwd": "/home/ftr/Apps/FTR10-Hermes-VSCode",
            "outFiles": [
                "/home/ftr/Apps/FTR10-Hermes-VSCode/out/**/*.js"
            ],
            "preLaunchTask": "${defaultBuildTask}"
        },
        {
            "name": "Extension Tests",
            "type": "extensionHost",
            "request": "launch",
            "program": "${workspaceFolder}",
            "args": [
                "--extensionDevelopmentPath=/home/ftr/Apps/FTR10-Hermes-VSCode",
                "--disable-extensions",
                "--no-cache"
            ],
            "cwd": "/home/ftr/Apps/FTR10-Hermes-VSCode",
            "outFiles": [
                "/home/ftr/Apps/FTR10-Hermes-VSCode/out/**/*.js"
            ],
            "preLaunchTask": "${defaultBuildTask}"
        }
    ]
}
