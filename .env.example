# Hermes VS Code extension — local environment configuration
#
# Copy this file to `.env` and adjust values for your machine.
# `.env` is git-ignored so secrets/URLs never get committed.
#
# Dashboard (Control Center) URL.
# The Control Center embeds the local Hermes dashboard. Use a loopback
# address — the dashboard is a local, machine-only service. Falls back to
# http://127.0.0.1:9119/config if unset and no env var is present.
# The HERMES_DASHBOARD_URL environment variable takes precedence over this file.
DASHBOARD_URL=http://127.0.0.1:9119/config
